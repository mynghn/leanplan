#!/usr/bin/env bash
# LeanPlan pre-commit hook.
#
# Installation (per repo, one of):
#   ln -s ~/.local/share/leanplan/scripts/pre-commit-leanplan  <repo>/.git/hooks/pre-commit
# or, if you already have per-repo pre-commits, chain it by calling this script
# from your existing hook.
#
# Behavior: warn mode by default (diagnostics on stderr, commit proceeds).
# Set LEANPLAN_STRICT=1 to escalate validator warnings to errors and block.

set -uo pipefail

VALIDATE="$HOME/.local/share/leanplan/scripts/validate.py"
if [ ! -f "$VALIDATE" ]; then
    # Nothing to do; don't obstruct the commit.
    exit 0
fi

# Pick up feature directories from staged feature-artifact paths.
keys=$(git diff --cached --name-only --diff-filter=ACM \
    | grep -E '^docs/features/[^/]+/.*\.md$' \
    | awk -F/ '{ print $3 }' \
    | sort -u)

if [ -z "$keys" ]; then
    exit 0
fi

# Pass --strict through to validate.py when LEANPLAN_STRICT=1; default is advisory.
strict_flag=""
[ "${LEANPLAN_STRICT:-0}" = "1" ] && strict_flag="--strict"

worst=0
for key in $keys; do
    # shellcheck disable=SC2086
    python3 "$VALIDATE" "docs/features/$key" $strict_flag
    ec=$?
    [ "$ec" -gt "$worst" ] && worst=$ec
done

if [ "$worst" -eq 0 ]; then
    exit 0
fi

if [ "${LEANPLAN_STRICT:-0}" = "1" ]; then
    echo "leanplan pre-commit: errors above — blocking (strict mode)" >&2
    exit "$worst"
else
    echo "leanplan pre-commit: diagnostics above — commit proceeds (set LEANPLAN_STRICT=1 to block)" >&2
    exit 0
fi
