#!/usr/bin/env bash
# LeanPlan commit-msg hook — flag round-scoped keys leaked into the commit message.
#
# Installation (per repo):
#   ln -s ~/.local/share/leanplan/scripts/commit-msg-leanplan  <repo>/.git/hooks/commit-msg
#
# Warn-by-default (diagnostics on stderr, commit proceeds); LEANPLAN_STRICT=1
# blocks. A commit message is a durable artifact read without the planning docs,
# so it must carry the reason in words, not a round-scoped anchor / citation.

set -uo pipefail

MSG_FILE="${1:-}"
SCAN="${LEANPLAN_SCAN:-$HOME/.local/share/leanplan/scripts/scan-leaks}"

[ -f "$SCAN" ] || exit 0                       # detector not installed; don't obstruct
[ -n "$MSG_FILE" ] && [ -f "$MSG_FILE" ] || exit 0

strict_flag=""
[ "${LEANPLAN_STRICT:-0}" = "1" ] && strict_flag="--strict"

# git strips comment-char lines from the final message, so scan only the lines
# that persist — otherwise the commit template / verbose diff comments would
# false-positive (a token in the staged diff is the pre-commit hook's concern).
comment_char="$(git config --get core.commentChar 2>/dev/null || true)"
if [ -z "$comment_char" ] || [ "$comment_char" = "auto" ]; then
    comment_char="#"
fi
msg_body="$(grep -v "^${comment_char}" "$MSG_FILE" || true)"

# shellcheck disable=SC2086
out=$(python3 "$SCAN" $strict_flag --text "$msg_body" 2>&1)
ec=$?

if [ "$ec" -eq 0 ] && ! printf '%s' "$out" | grep -qE '^(WARNING|ERROR):'; then
    exit 0
fi
printf '%s\n' "$out" >&2
if [ "${LEANPLAN_STRICT:-0}" = "1" ]; then
    echo "leanplan commit-msg: round-scoped key in message — blocking (strict mode)" >&2
    exit "$ec"
else
    echo "leanplan commit-msg: diagnostics above — commit proceeds (set LEANPLAN_STRICT=1 to block)" >&2
    exit 0
fi
