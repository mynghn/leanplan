#!/usr/bin/env bash
# leanplan-selftest: verify validate.py catches injected defects against a known-good fixture.
#
# Fixture defaults to the bundled valid/ fixture; override via
# LEANPLAN_FIXTURE=<path-to-known-good-feature-dir>. Scenarios run in ephemeral
# temp dirs; the fixture is never mutated.

set -uo pipefail

# Resolve the script directory; default fixture is the bundled valid/ next to this script.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_FIXTURE="$(cd "$SCRIPT_DIR/.." && pwd)/fixtures/valid"

FIXTURE="${LEANPLAN_FIXTURE:-$DEFAULT_FIXTURE}"
VALIDATE="${LEANPLAN_VALIDATE:-$SCRIPT_DIR/validate.py}"
SCAN="${LEANPLAN_SCAN:-$SCRIPT_DIR/scan-leaks}"
LEANPLAN_NEW="${LEANPLAN_NEW:-$SCRIPT_DIR/leanplan-new}"

if [ ! -d "$FIXTURE" ]; then
    echo "error: fixture not found at $FIXTURE (set LEANPLAN_FIXTURE to override)" >&2
    exit 2
fi
if [ ! -x "$VALIDATE" ] && ! [ -f "$VALIDATE" ]; then
    echo "error: validate.py not found at $VALIDATE" >&2
    exit 2
fi
if [ ! -x "$SCAN" ] && ! [ -f "$SCAN" ]; then
    echo "error: scan-leaks not found at $SCAN" >&2
    exit 2
fi
if [ ! -x "$LEANPLAN_NEW" ] && ! [ -f "$LEANPLAN_NEW" ]; then
    echo "error: leanplan-new not found at $LEANPLAN_NEW" >&2
    exit 2
fi

TMP=$(mktemp -d)
trap 'rm -rf "$TMP"' EXIT

pass=0
fail=0

# task_file: returns the Tasks artifact filename present in the fixture (tasks.md).
task_file() {
    if [ -f "$1/tasks.md" ]; then echo "tasks.md"; else echo "tasks.md"; fi
}

assert_case() {
    local label="$1" expected_ec="$2" expected_stderr_substr="$3" injection_fn="$4"
    local extra_flags="${5:-}"

    local case_dir="$TMP/LP-EXAMPLE"
    rm -rf "$case_dir"
    mkdir -p "$case_dir"
    cp -R "$FIXTURE/." "$case_dir/"

    "$injection_fn" "$case_dir"

    local out ec
    # shellcheck disable=SC2086
    out=$(python3 "$VALIDATE" "$case_dir" $extra_flags 2>&1)
    ec=$?

    if [ "$ec" -eq "$expected_ec" ] && printf '%s' "$out" | grep -qF -- "$expected_stderr_substr"; then
        printf 'PASS %s\n' "$label"
        pass=$((pass + 1))
    else
        printf 'FAIL %s  (expected exit=%d with output ~ %q; got exit=%d)\n' \
            "$label" "$expected_ec" "$expected_stderr_substr" "$ec"
        printf '  --- output ---\n%s\n  --- end ---\n' "$out"
        fail=$((fail + 1))
    fi
}

# scan_case: write CONTENT to a temp non-artifact file, run scan-leaks over it,
# and check exit code + an expected output substring. The leak detector's
# regression backstop — assert_case's role, for scan-leaks instead of validate.py.
scan_case() {
    local label="$1" content="$2" expected_ec="$3" expected_substr="$4"
    local extra_flags="${5:-}"

    local f="$TMP/scan-input.txt"
    printf '%s\n' "$content" > "$f"

    local out ec
    # shellcheck disable=SC2086
    out=$(python3 "$SCAN" "$f" $extra_flags 2>&1)
    ec=$?

    if [ "$ec" -eq "$expected_ec" ] && printf '%s' "$out" | grep -qF -- "$expected_substr"; then
        printf 'PASS %s\n' "$label"
        pass=$((pass + 1))
    else
        printf 'FAIL %s  (expected exit=%d with output ~ %q; got exit=%d)\n' \
            "$label" "$expected_ec" "$expected_substr" "$ec"
        printf '  --- output ---\n%s\n  --- end ---\n' "$out"
        fail=$((fail + 1))
    fi
}

# rename_case: exercise `leanplan-new --rename` in a throwaway mini-repo. Builds
# docs/features/<old> from the fixture (H1 set to match the key so the H1 refresh
# has work), runs an optional SETUP_FN against the repo root (siblings, refs), runs
# the rename, then checks exit code + a PREDICATE eval'd at the repo root. This is
# do_rename's only automated coverage — assert_case/scan_case drive validate.py /
# scan-leaks, so the move/rewrite/H1/residual-gate/rollback/guards path would
# otherwise regress with the suite still green.
rename_case() {
    local label="$1" old="$2" new="$3" expected_ec="$4" predicate="$5" setup_fn="${6:-}"
    local repo="$TMP/rn-repo"
    rm -rf "$repo"; mkdir -p "$repo/docs/features"
    if [ "$old" != "-" ]; then
        cp -R "$FIXTURE" "$repo/docs/features/$old"
        sed -i.bak -E "1s/^# [A-Za-z0-9-]+ /# $old /" "$repo/docs/features/$old"/*.md
        rm -f "$repo/docs/features/$old"/*.bak
    fi
    [ -n "$setup_fn" ] && "$setup_fn" "$repo"
    local out ec
    out=$(cd "$repo" && "$LEANPLAN_NEW" --rename "$old" "$new" 2>&1); ec=$?
    local ok=1 why=""
    [ "$ec" -eq "$expected_ec" ] || { ok=0; why="exit=$ec want=$expected_ec"; }
    if [ -n "$predicate" ] && ! ( cd "$repo" && eval "$predicate" ); then ok=0; why="$why; predicate failed"; fi
    if [ "$ok" -eq 1 ]; then
        printf 'PASS %s\n' "$label"; pass=$((pass + 1))
    else
        printf 'FAIL %s  (%s)\n  --- output ---\n%s\n  --- end ---\n' "$label" "$why" "$out"; fail=$((fail + 1))
    fi
}

# setup helpers for rename_case (run at the repo root)
rn_setup_sibling_and_ref() {
    # A sibling sharing the renamed key's prefix + a file referencing both: the
    # rename must rewrite the target ref and leave the sibling's ref untouched.
    cp -R "$FIXTURE" "$1/docs/features/0007-old-sibling"
    printf 'see docs/features/0007-old/spec.md and docs/features/0007-old-sibling/spec.md\n' > "$1/ref.md"
}
rn_setup_unreadable_ref() {
    # A referencing file grep can't read forces a scan read-error mid-rewrite; the
    # rename must abort and roll the move back rather than strand a half-rename.
    printf 'see docs/features/0007-old/spec.md\n' > "$1/ref.md"
    chmod 000 "$1/ref.md"
}

inject_baseline() { :; }

inject_ascii_architecture() {
    perl -0pi.bak -e 's/```mermaid\n.*?```/```ascii\n[script] -> [runtime]\n    |          ^\n    +----------+\n```/s' "$1/design.md"
    rm -f "$1/design.md.bak"
}

inject_broken_anchor() {
    local f
    f=$(task_file "$1")
    sed -i.bak 's/Spec#B-1-single-invocation-sync/Spec#B-99-bogus/g' "$1/$f"
    rm -f "$1/$f.bak"
}

inject_duplicate_delta() {
    # Append-only integrity: re-emitting an existing Delta id (the easy mistake
    # when /sharpen is re-invoked across stateless sessions) must be caught.
    cat > "$1/understanding-shifts.md" <<'U'
# LP-EXAMPLE — Understanding

## Delta-1: premise-falsified
The understanding now is X; prior assumption Y is killed.

## Delta-1: premise-falsified
A second block reusing the same id — must be flagged.
U
}

inject_coverage_hole() {
    local f
    f=$(task_file "$1")
    # Remove every reference to the second behavior anchor (both citation and bare-ID forms).
    sed -i.bak -E '/Spec#B-2/d; /B-2 staleness-reporting/d' "$1/$f"
    rm -f "$1/$f.bak"
}

inject_req_drift() {
    printf '\nThe system uses Kafka for event streaming.\n' >> "$1/requirements.md"
}

inject_task_step_drift() {
    local f
    f=$(task_file "$1")
    printf '\n- edit file src/app.ts at line 42 to add config\n' >> "$1/$f"
}

inject_surface_bloat() {
    # Pad spec.md well past its ~110-line soft cap (Spec) with filler lines, to trip the
    # surface-budget guardrail (advisory; escalates to error under --strict).
    local i
    for i in $(seq 1 200); do printf '<!-- filler %d -->\n' "$i" >> "$1/spec.md"; done
}

inject_outcome_only_task() {
    # Append a task whose ONLY reason citation is a Behavior anchor (no Constraint,
    # no Decision). Regression guard for the reverse-coverage matcher: it must accept
    # Behavior-only tasks (the contract permits them; trivial-realization features
    # rely on them). Previously the matcher keyed on the dropped 'AC' token and
    # rejected this, masked only because every fixture task also cited C/Design.
    local f
    f=$(task_file "$1")
    cat >> "$1/$f" <<'CARD'

## T: S9

**Goal**: Behavior-only task — realizes the published contract per `Spec#B-1-single-invocation-sync`.

**Repo**: leanplan

**Completion**:
- Observable proof per `Spec#B-1-single-invocation-sync`.

**Dependencies**: none
CARD
}

inject_understanding_citation_ok() {
    # A revised artifact cites the Delta that justified it, and the delta exists,
    # so the inbound Understanding#Delta-N citation must RESOLVE (parity with
    # Spec#/Design#). Guards the auditable-justification link: a revised artifact
    # can cite the delta that justified it and have that link checked.
    cat > "$1/understanding-shifts.md" <<'U'
# LP-EXAMPLE — Understanding

## Delta-1: premise-falsified
The understanding now is X; prior assumption Y is killed.
U
    printf '\nRevised per `Understanding#Delta-1-premise-falsified`.\n' >> "$1/design.md"
}

inject_understanding_citation_broken() {
    # An inbound Understanding# citation with no matching delta must now ERROR.
    # Before C this was unconditionally skipped (always passed); the skip is gone.
    printf '\nRevised per `Understanding#Delta-9-nonexistent`.\n' >> "$1/design.md"
}

inject_defer_anchor_and_citation_resolve() {
    # F2: a deferrals.md Defer-N block + an inbound Deferrals#Defer-N citation must
    # resolve — the anchor parses (Defer is ordered before D in ANCHOR_RE) and the
    # Deferrals# citation form is recognized. Marked resolved so it stays clean once
    # the L1 no-loss check lands (a drained deferral is the steady state); the
    # resolve-in-place marker's Design# target resolves against the fixture's D-2.
    cat > "$1/deferrals.md" <<'D'
# LP-EXAMPLE — Deferrals

## Defer-1: cache-strategy (resolved -> Design#D-2-in-repo-path-hard-coded)

**Owning stage**: Design

The open question: which cache strategy; surfaced while specifying behavior.

Forces: latency vs consistency.

Option seen (not chosen): write-through cache.
D
    printf '\nResolved the parked `Deferrals#Defer-1-cache-strategy`.\n' >> "$1/design.md"
}

inject_duplicate_defer() {
    # Append-only integrity for the new lane: re-emitting an existing Defer id must
    # be caught (parity with the duplicate-Delta guard).
    cat > "$1/deferrals.md" <<'D'
# LP-EXAMPLE — Deferrals

## Defer-1: cache-strategy

**Owning stage**: Tasks

The open question; surfaced mid-design.

## Defer-1: cache-strategy

A second block reusing the same id — must be flagged.
D
}

inject_broken_defer_citation() {
    # An inbound Deferrals# citation with no matching Defer anchor must ERROR
    # (parity with the broken Spec#/Understanding# citation guards).
    printf '\nSee `Deferrals#Defer-9-nonexistent`.\n' >> "$1/design.md"
}

inject_defer_undrained() {
    # L1 no-loss: an unresolved Defer-N addressed to a stage whose artifact already
    # exists (Design here) is an undrained deferral — the advisory warns by default
    # and errors under --strict. No resolve-in-place marker on the heading.
    cat > "$1/deferrals.md" <<'D'
# LP-EXAMPLE — Deferrals

## Defer-1: cache-strategy

**Owning stage**: Design

The open question: which cache strategy; surfaced while specifying behavior.

Forces: latency vs consistency.
D
}

inject_defer_future_stage() {
    # L1 no-loss: an unresolved Defer-N addressed to a stage NOT yet authored is
    # legitimate — no warning. Addressed to Tasks, with tasks.md removed and
    # validation run through --stage design, so tasks.md is genuinely absent.
    cat > "$1/deferrals.md" <<'D'
# LP-EXAMPLE — Deferrals

## Defer-1: cache-strategy

**Owning stage**: Tasks

The open question: which cache strategy; surfaced while specifying behavior.
D
    rm -f "$1/tasks.md"
}

inject_defer_nl_owner() {
    # L1 robustness: a natural-language owner phrasing ("the Design stage") must still
    # resolve to the stage and warn — not silently skip on off-canonical wording.
    cat > "$1/deferrals.md" <<'D'
# LP-EXAMPLE — Deferrals

## Defer-1: cache-strategy

**Owning stage**: the Design stage

The open question: which cache strategy; surfaced while specifying behavior.
D
}

inject_defer_inbody_heading() {
    # L1 robustness: a stray markdown heading in the block body, before the owner
    # line, must not truncate the owner search — the warning must still fire (blocks
    # are bounded by the next anchor, not the next markdown heading).
    cat > "$1/deferrals.md" <<'D'
# LP-EXAMPLE — Deferrals

## Defer-1: cache-strategy

# rough sketch of the option space

**Owning stage**: Design

The open question: which cache strategy; surfaced while specifying behavior.
D
}

inject_retired_anchor() {
    # Retire-by-note on a heading must keep the anchor's ID resolvable: marking
    # B-1's heading (retired) must NOT break its inbound tasks.md citation or the
    # "at least one B anchor" check — a retired item's ID must keep resolving so
    # prior work stays reconstructable, not silently deleted.
    sed -i.bak -E 's/^(#{2,4} B-1: single-invocation-sync)$/\1 (retired)/' "$1/spec.md"
    rm -f "$1/spec.md.bak"
}

inject_retired_task() {
    # Retiring a Tasks card heading must keep it parseable so its ID still resolves
    # (no silent drop — the asymmetric risk the T: retire form would otherwise
    # carry). The appended card is cited via Tasks#T:Z9, which resolves only if
    # the (retired)-marked heading is still parsed.
    local f
    f=$(task_file "$1")
    cat >> "$1/$f" <<'CARD'

## T: Z9 (retired)

**Goal**: Superseded task kept for history, per `Spec#B-1-single-invocation-sync`.

**Completion**:
- n/a — retired; superseding work covers `Spec#B-1-single-invocation-sync`.

**Dependencies**: none

Superseded; retained for traceability — see `Tasks#T:Z9`.
CARD
}

inject_retired_sole_coverage() {
    # A live Spec behavior whose ONLY covering task is retired must FAIL coverage:
    # retire-by-note keeps the superseded card for history, but a dead task grants
    # no forward-coverage credit — else retiring the last task of a live behavior
    # silently passes a real coverage hole.
    cat >> "$1/spec.md" <<'ITEM'

### B-9: retired-sole-coverage
When the only task covering a behavior is retired, coverage must fail.
ITEM
    local f
    f=$(task_file "$1")
    cat >> "$1/$f" <<'CARD'

## T: R9 (retired)

**Goal**: Superseded — once covered `Spec#B-9-retired-sole-coverage`.

**Completion**:
- n/a — retired; per `Spec#B-9-retired-sole-coverage`.

**Dependencies**: none
CARD
}

inject_remove_gap() {
    # Strip the **GAP** ack from the only GAP-acked item (C-3) so it becomes a
    # real coverage hole. Locks that the GAP-ack branch actually FLIPS the verdict:
    # the same item passes WITH the ack (baseline) and must FAIL without it. No
    # other fixture isolates this — proves _gap_acknowledged_targets is load-bearing.
    local f
    f=$(task_file "$1")
    sed -i.bak 's/\*\*GAP\*\*/(ack removed)/' "$1/$f"
    rm -f "$1/$f.bak"
}

inject_design_links_absent_rationale() {
    # Delete design-rationale.md entirely while design.md still links it
    # (D-2, D-6). The design->rationale link check must fire even
    # when the whole rationale file is ABSENT (not just missing a block) — guards
    # the fix that dropped the early-return which silently passed this worse case.
    rm -f "$1/design-rationale.md"
}

# Validate.py exit semantics:
#   0 = clean (no errors; warnings allowed in default mode)
#   1 = at least one error (or any warning under --strict)
assert_case "baseline (clean fixture)"        0 "validation passed"                     inject_baseline
assert_case "ascii architecture visual"       0 "validation passed"                     inject_ascii_architecture
assert_case "broken anchor"                   1 "broken citation"                       inject_broken_anchor
assert_case "duplicate delta anchor"          1 "duplicate anchor: Delta-1"             inject_duplicate_delta
assert_case "coverage hole"                   1 "is not covered by any task"            inject_coverage_hole
assert_case "requirement drift (--strict)"    1 "implementation choice in Requirements"  inject_req_drift          "--strict"
assert_case "task step drift (--strict)"      1 "looks like line-level scripting"       inject_task_step_drift    "--strict"
assert_case "surface bloat (--strict)"        1 "soft cap"                               inject_surface_bloat      "--strict"
assert_case "behavior-only task reason"       0 "validation passed"                     inject_outcome_only_task  "--strict"
assert_case "understanding citation resolves"  0 "validation passed"                     inject_understanding_citation_ok
assert_case "broken understanding citation"    1 "broken citation: Understanding#Delta-9-nonexistent" inject_understanding_citation_broken
assert_case "defer anchor + citation resolve"  0 "validation passed"                     inject_defer_anchor_and_citation_resolve
assert_case "duplicate defer anchor"           1 "duplicate anchor: Defer-1"              inject_duplicate_defer
assert_case "broken defer citation"            1 "broken citation: Deferrals#Defer-9-nonexistent" inject_broken_defer_citation
assert_case "undrained defer warns"            0 "undrained deferral"                     inject_defer_undrained
assert_case "undrained defer errors (--strict)" 1 "undrained deferral"                    inject_defer_undrained    "--strict"
assert_case "defer for unauthored stage ok"    0 "validation passed"                     inject_defer_future_stage "--stage design"
assert_case "defer natural-language owner warns" 0 "undrained deferral"                   inject_defer_nl_owner
assert_case "defer in-body heading still warns"  0 "undrained deferral"                    inject_defer_inbody_heading
assert_case "retired anchor still resolves"    0 "validation passed"                     inject_retired_anchor
assert_case "retired task still resolves"      0 "validation passed"                     inject_retired_task
assert_case "retired task grants no coverage"  1 "is not covered by any task: Spec#B-9-retired-sole-coverage" inject_retired_sole_coverage
assert_case "gap ack removed -> coverage hole" 1 "is not covered by any task: Spec#C-3-atomicity-under-failure" inject_remove_gap
assert_case "design links absent rationale"    1 "Design links to missing rationale block" inject_design_links_absent_rationale

# scan-leaks defect injection: round-scoped keys leaked into a non-artifact file
# must be caught — defect-injection coverage for the per-surface leak backstop.
# Exit semantics mirror validate.py —
# a leak warns (exit 0) by default and escalates to error (exit 1) under --strict;
# the grey zone (feature ids, readable scope labels, bare numbers) stays clean,
# and the inline directive suppresses even under --strict.
scan_case "scan: bare anchor C-1 leak (warn)"       'satisfies C-1 in this code'                  0 "C-1"
scan_case "scan: bare anchor C-1 leak (strict)"     'satisfies C-1 in this code'                  1 "C-1"         "--strict"
scan_case "scan: citation Spec#C-1 leak (strict)"   'see Spec#C-1-durable-artifacts here'         1 "Spec#C-1"    "--strict"
scan_case "scan: feature id + scope label clean"    'docs(lean-review-surfaces): feature 0004-x'  0 "clean"
scan_case "scan: bare number + commit sha clean"    'retry after 2; pinned at 6184aa2'            0 "clean"
scan_case "scan: inline directive suppresses"       'satisfies C-1  # leanplan-allow-key'         0 "clean"       "--strict"

# Every anchor kind + a non-Spec citation must be caught — not only the kinds above,
# else a regex edit dropping an alternation regresses with the suite still green.
# D-2 then Delta-3 also guard the Delta-before-D alternation order (D is a prefix of Delta).
scan_case "scan: bare anchor B-1 leak (strict)"        'see the B-1 baseline here'               1 "B-1"               "--strict"
scan_case "scan: bare anchor D-2 leak (strict)"        'following D-2 we chose X'                1 "D-2"               "--strict"
scan_case "scan: bare anchor Delta-3 leak (strict)"    'per Delta-3 the assumption changed'       1 "Delta-3"           "--strict"
scan_case "scan: bare anchor Defer-2 leak (strict)"    'parked as Defer-2 earlier'               1 "Defer-2"           "--strict"
scan_case "scan: citation Design# leak (strict)"       'see Design#D-2-narrow here'              1 "Design#D-2"        "--strict"
scan_case "scan: citation Deferrals# leak (strict)"    'see Deferrals#Defer-1-cache here'        1 "Deferrals#Defer-1" "--strict"

# --text is the commit-msg hook's only input path; exercise it, the exit-2 input
# error contract, and the anchor-inside-citation dedup directly.
out=$(python3 "$SCAN" --strict --text 'satisfies C-1 here' 2>&1); ec=$?
if [ "$ec" -eq 1 ] && printf '%s' "$out" | grep -qF -- "C-1"; then
    printf 'PASS %s\n' "scan: --text mode leak (strict)"; pass=$((pass + 1))
else
    printf 'FAIL %s  (expected exit=1 with C-1; got exit=%d)\n  --- output ---\n%s\n  --- end ---\n' \
        "scan: --text mode leak (strict)" "$ec" "$out"; fail=$((fail + 1))
fi

out=$(python3 "$SCAN" "$TMP/nonexistent-$$.txt" 2>&1); ec=$?
if [ "$ec" -eq 2 ]; then
    printf 'PASS %s\n' "scan: missing file -> exit 2"; pass=$((pass + 1))
else
    printf 'FAIL %s  (expected exit=2; got exit=%d)\n  --- output ---\n%s\n  --- end ---\n' \
        "scan: missing file -> exit 2" "$ec" "$out"; fail=$((fail + 1))
fi

out=$(python3 "$SCAN" --json --text 'see Spec#C-1-durable here' 2>&1)
ntok=$(printf '%s' "$out" | grep -c '"token"')
if [ "$ntok" -eq 1 ]; then
    printf 'PASS %s\n' "scan: citation dedup (single token)"; pass=$((pass + 1))
else
    printf 'FAIL %s  (expected 1 token, got %d)\n  --- output ---\n%s\n  --- end ---\n' \
        "scan: citation dedup (single token)" "$ntok" "$out"; fail=$((fail + 1))
fi

# --- leanplan-new --rename coverage (do_rename: move, rewrite, H1, residual gate, rollback, guards) ---
rn_setup_make_new() { mkdir -p "$1/docs/features/0008-new"; }

# happy-path: relocate + rewrite the target ref + refresh H1, while a sibling that
# shares the key's prefix (and its reference) is left untouched (boundary safety).
rename_case "rename: relocates, rewrites ref, spares sibling" 0007-old 0008-new 0 \
    '[ -d docs/features/0008-new ] && [ ! -d docs/features/0007-old ] && [ -d docs/features/0007-old-sibling ] && grep -q "docs/features/0008-new/spec.md" ref.md && grep -q "docs/features/0007-old-sibling/spec.md" ref.md && grep -q "^# 0008-new " docs/features/0008-new/spec.md' \
    rn_setup_sibling_and_ref

# guard: refuse to overwrite an existing target dir; the source must stay put.
rename_case "rename: refuses existing target (exit 2)" 0007-old 0008-new 2 \
    '[ -d docs/features/0007-old ] && [ -d docs/features/0008-new ]' rn_setup_make_new

# guard: a path-traversal / non-key new id is rejected before anything moves.
rename_case "rename: rejects traversal key (exit 1)" 0007-old ../escape 1 \
    '[ -d docs/features/0007-old ]'

# rollback: an unreadable referencing file makes the scan error mid-rewrite; the
# move must be reversed so nothing is left half-renamed.
rename_case "rename: rolls back on scan read-error" 0007-old 0008-new 1 \
    '[ -d docs/features/0007-old ] && [ ! -d docs/features/0008-new ]' rn_setup_unreadable_ref

# mid-flight: a stub-only feature fails full validation but must still rename
# (reachable at any in-flight stage), emitting an informational note not an error.
rn_mf="$TMP/rn-midflight"; rm -rf "$rn_mf"; mkdir -p "$rn_mf/docs/features"
mf_dir=$(cd "$rn_mf" && "$LEANPLAN_NEW" --date=260601 "mid flight" 2>/dev/null)
mf_key=$(basename "$mf_dir")
out=$(cd "$rn_mf" && "$LEANPLAN_NEW" --rename "$mf_key" 260601-renamed 2>&1); ec=$?
if [ "$ec" -eq 0 ] && [ -d "$rn_mf/docs/features/260601-renamed" ] && printf '%s' "$out" | grep -q 'pre-existing validation issues'; then
    printf 'PASS %s\n' "rename: mid-flight feature renames with note"; pass=$((pass + 1))
else
    printf 'FAIL %s  (expected exit=0 + note; got exit=%d)\n  --- output ---\n%s\n  --- end ---\n' \
        "rename: mid-flight feature renames with note" "$ec" "$out"; fail=$((fail + 1))
fi

printf '\nselftest: %d passed, %d failed\n' "$pass" "$fail"
exit "$fail"
