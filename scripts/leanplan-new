#!/usr/bin/env bash
# leanplan-new: allocate a feature id and scaffold its artifact stubs.
#
# Usage:
#   leanplan-new <slug-or-title>          # sequence id:    NNNN-slug     (e.g. 0007-anomaly-publisher)
#   leanplan-new <PROJ-123>               # tracker key:    PROJ-123      (bare, e.g. a Jira issue key)
#   leanplan-new --date <slug-or-title>   # date id:        YYMMDD-slug   (e.g. 260616-anomaly-publisher)
#   leanplan-new --date=YYMMDD <title>    # date id with an explicit date instead of today
#   leanplan-new --rename <old> <new>     # relocate an existing feature, rewrite refs, re-validate
#
# The feature id comes in three forms; leanplan-new picks one as follows:
#   1. --date present                     -> date id:     <YYMMDD>-<slug>  (YYMMDD = today, or --date=NNNNNN)
#   2. arg matches [A-Z][A-Z0-9]*-[0-9]+  -> tracker key: the arg verbatim, BARE (no slug; already unique)
#   3. otherwise                          -> sequence id: <NNNN>-<slug>    (scan docs/features/ for the highest
#                                            WIDTH-digit number, +1, zero-padded — width via $LEANPLAN_ID_WIDTH,
#                                            default 4)
# Forms 1 and 3 normalize the title arg to a kebab slug; form 2 uses the key as-is.
# Creates <cwd>/docs/features/<id>/{requirements,spec,design,design-rationale,tasks}.md.
# Stubs contain section headers + guidance comments — no pseudo-items — so a fresh
# scaffold passes all validators cleanly. The corresponding /requirements, /specify,
# /design, /tasks skills fill in real content.
#
# Prints the allocated relative dir path (docs/features/<id>) to STDOUT as the only
# stdout output, so a caller can capture it: dir=$(leanplan-new "$title").
# Human-facing messages go to stderr. Exit codes: 0 success; 1 bad input
# (missing/empty arg, bad LEANPLAN_ID_WIDTH, bad --date value) or a --rename that aborts
# (unreadable file mid-scan, or a reference left stranded); 2 feature dir already exists.

set -euo pipefail

FEATURES_ROOT="docs/features"

usage() {
    cat <<'EOF'
leanplan-new — allocate a feature id and scaffold its artifact stubs.

Usage:
  leanplan-new <slug-or-title>           sequence id:  NNNN-slug
  leanplan-new <PROJ-123>                tracker key:  PROJ-123 (bare)
  leanplan-new --date[=YYMMDD] <title>   date id:      YYMMDD-slug
  leanplan-new --rename <old> <new>      relocate an existing feature, rewrite refs

Prints the allocated docs/features/<id> path on stdout; messages on stderr.
Exit: 0 ok / 1 bad input or rename failure / 2 target dir exists.
EOF
}

# Normalize to a kebab slug. The [a-z0-9-] charset is LOAD-BEARING, not cosmetic:
# it collapses '/' and '.' to '-', so a slug can never introduce a path separator
# and escape docs/features/. Do not relax it without re-adding an explicit
# `case "$SLUG" in */*|*..*) reject` guard. (The tracker-key form is exempt — it
# is independently constrained to [A-Z0-9-] by its detection regex below.)
slugify() {
    printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//'
}

# do_rename <old> <new>: relocate an existing feature and leave nothing stranded.
# Moves docs/features/<old> -> docs/features/<new>, rewrites every intra-repo
# reference to the old path, refreshes the moved artifacts' H1 self-identity, then
# re-validates. The reference-rewrite + re-validate is exactly the step a raw `mv`
# skips — the omission that stranded stubs unread at the old path.
do_rename() {
    if [ $# -ne 2 ]; then
        echo "usage: leanplan-new --rename <old-key> <new-key>" >&2
        exit 1
    fi
    local OLD="$1" NEW="$2" k f

    # KEY charset gate: [A-Za-z0-9-] only (covers all three id forms), no leading
    # dash. Load-bearing twice — it stops a key from smuggling a path separator
    # (so a rename can never escape docs/features/), and keeps OLD/NEW free of
    # regex metacharacters before they are interpolated into the grep/sed below.
    for k in "$OLD" "$NEW"; do
        case "$k" in
            ''|-*|*[!A-Za-z0-9-]*)
                echo "error: invalid feature key '$k' — keys are [A-Za-z0-9-], no leading dash" >&2
                exit 1 ;;
        esac
    done
    if [ "$OLD" = "$NEW" ]; then
        echo "error: <old> and <new> are the same key ('$OLD') — nothing to rename" >&2
        exit 1
    fi

    local OLD_DIR="$FEATURES_ROOT/$OLD" NEW_DIR="$FEATURES_ROOT/$NEW"
    if [ ! -d "$OLD_DIR" ]; then
        echo "error: $OLD_DIR does not exist" >&2
        exit 1
    fi
    if [ -e "$NEW_DIR" ]; then
        # Limitation: on a case-insensitive filesystem (default macOS/Windows) a
        # case-only rename (FOO -> foo) resolves to the same inode and trips here.
        # No corruption — mv never runs — but the fix is a two-step rename through
        # an intermediate key.
        echo "error: $NEW_DIR already exists — refusing to overwrite" >&2
        exit 2
    fi

    local SCRIPT_DIR
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

    # Atomicity: steps 1-3 below mutate the tree (move, repo-wide rewrite, H1
    # refresh). A failure partway must leave NOTHING changed — otherwise the move
    # lands, references are half-rewritten, and the feature is stranded at a path
    # nothing points to: exactly what this command exists to prevent. We arm a
    # trap (EXIT + INT/TERM — SIGKILL alone can't be trapped, so `kill -9` mid-rewrite
    # is the one unrecoverable case) that restores every rewritten file from its `.bak`
    # and reverses the move, and disarm it only once the rename has fully held. Rollback state is
    # script-global so the trap can see it regardless of function-local scope at
    # exit (bash-3.2-safe; guarded array expansion avoids the empty-array nounset
    # trap).
    _RENAME_OLD_DIR="$OLD_DIR"
    _RENAME_NEW_DIR="$NEW_DIR"
    _RENAME_MOVED=0
    _RENAME_BAKS=()
    _rename_rollback() {
        local ec=$? b
        trap - EXIT INT TERM
        if [ "${#_RENAME_BAKS[@]}" -gt 0 ]; then
            for b in "${_RENAME_BAKS[@]}"; do
                [ -f "$b" ] && mv -f "$b" "${b%.bak}"
            done
        fi
        if [ "$_RENAME_MOVED" -eq 1 ] && [ -d "$_RENAME_NEW_DIR" ] && [ ! -e "$_RENAME_OLD_DIR" ]; then
            mv "$_RENAME_NEW_DIR" "$_RENAME_OLD_DIR"
        fi
        echo "rolled back: rename aborted, working tree restored to its pre-rename state" >&2
        exit "$ec"
    }
    trap _rename_rollback EXIT INT TERM

    # 1. Move the directory. Filesystem-level so it works with or without git;
    #    git records it as a rename on the next `git add -A` via content
    #    similarity, preserving blame/history so prior work stays reconstructable.
    mv "$OLD_DIR" "$NEW_DIR"
    _RENAME_MOVED=1

    # 2. Rewrite intra-repo references to the OLD feature path -> NEW, repo-wide.
    #    The `([^A-Za-z0-9-]|$)` boundary is load-bearing: without it the pattern
    #    `docs/features/foo` would also match a sibling `docs/features/foo-bar` and
    #    corrupt its path. -i.bak is the GNU/BSD-portable in-place idiom; the `.bak`
    #    is kept (not rm'd inline) so the trap can restore it, and removed only on
    #    success. grep's exit is checked, not swallowed: a read error (exit > 1,
    #    e.g. an unreadable file) must abort+rollback, because a silently skipped
    #    file keeps its stale reference and strands it; exit 1 (no matches) is the
    #    only non-zero we tolerate. -I skips binaries; .git is excluded.
    local refs grep_ec=0
    refs=$(grep -rIl --exclude-dir=.git -- "docs/features/${OLD}" . 2>/dev/null) || grep_ec=$?
    if [ "$grep_ec" -gt 1 ]; then
        echo "error: could not scan the repo for references (grep exit $grep_ec) — a file was unreadable; aborting before anything is stranded" >&2
        exit 1
    fi
    while IFS= read -r f; do
        [ -n "$f" ] || continue
        _RENAME_BAKS+=("$f.bak")
        sed -i.bak -E "s#docs/features/${OLD}([^A-Za-z0-9-]|\$)#docs/features/${NEW}\1#g" "$f"
    done <<< "$refs"

    # 3. Refresh the moved artifacts' H1 self-identity. `# <old> — STAGE` is the
    #    one place each artifact still names the old key after step 2 (citations
    #    are key-agnostic anchors). Restrict the substitution to line 1 (`1s`) so a
    #    body line that happens to start `# <old> ` is never rewritten; if the H1
    #    key was hand-drifted from the dir name it simply won't match, left as-is.
    for f in "$NEW_DIR"/*.md; do
        [ -f "$f" ] || continue
        _RENAME_BAKS+=("$f.bak")
        sed -i.bak -E "1s/^# ${OLD} /# ${NEW} /" "$f"
    done

    # 3.5 Residual-reference gate — the real "nothing stranded" proof. After the
    #     rewrite, NO boundary-correct docs/features/<old> reference may survive
    #     anywhere. validate.py can't see this (it resolves only FILE#ANCHOR
    #     citations, never docs/features/<X> path tokens), so THIS re-scan — not
    #     re-validation — is what proves the rewrite was complete. Same boundary as
    #     step 2, so a sibling sharing the prefix never counts. A survivor is a
    #     reference the rewrite missed: abort, and the trap rolls everything back.
    #     `--exclude=*.bak` skips the rollback backups step 2 just wrote — they
    #     deliberately still hold the OLD content and would otherwise self-trip this.
    local residual rg_ec=0
    residual=$(grep -rIlE --exclude-dir=.git --exclude='*.bak' -- "docs/features/${OLD}([^A-Za-z0-9-]|\$)" . 2>/dev/null) || rg_ec=$?
    if [ "$rg_ec" -gt 1 ]; then
        echo "error: could not re-scan for residual references (grep exit $rg_ec)" >&2
        exit 1
    fi
    if [ -n "$residual" ]; then
        echo "error: references to docs/features/${OLD} survived the rewrite — stranded in:" >&2
        echo "$residual" >&2
        exit 1
    fi

    # 4. Re-validate the renamed feature (informational, NOT the stranding gate —
    #    that is 3.5). The rewrite + line-1 H1 refresh cannot break the feature's
    #    own validation: citations are key-agnostic FILE#ANCHOR anchors and
    #    validate.py never inspects the H1. So a non-clean result here is the
    #    feature's pre-existing state (e.g. mid-flight stubs), reported but not a
    #    rename fault — a rename must work at any in-flight stage.
    local out validation_note=""
    if ! out=$(python3 "$SCRIPT_DIR/validate.py" "$NEW_DIR" 2>&1); then
        validation_note="$out"
    fi

    # Success: the rename held (nothing stranded). Discard the backups and disarm
    # the rollback before the normal-exit messages, so the trap never fires clean.
    if [ "${#_RENAME_BAKS[@]}" -gt 0 ]; then
        for f in "${_RENAME_BAKS[@]}"; do rm -f "$f"; done
    fi
    trap - EXIT INT TERM

    if [ -n "$validation_note" ]; then
        echo "note: renamed $OLD -> $NEW; the feature has pre-existing validation issues (unrelated to the rename):" >&2
        echo "$validation_note" >&2
    fi

    echo "renamed $OLD -> $NEW at $NEW_DIR (references rewritten, none stranded)" >&2
    echo "$NEW_DIR"
    exit 0
}

# --help anywhere prints usage and exits clean, so `leanplan-new --help` is
# discoverable instead of being reported as an unknown option.
case "${1:-}" in --help|-h) usage; exit 0 ;; esac

# --rename short-circuits the allocator: it relocates an existing feature rather
# than allocating a new id, so it has its own arg shape and exits before the
# allocate path below.
if [ "${1:-}" = "--rename" ]; then
    shift
    do_rename "$@"
fi

# --- parse args: optional --date[=YYMMDD] flag plus one positional (title or key) ---
DATE_MODE=0
DATE_VALUE=""
RAW=""
while [ $# -gt 0 ]; do
    case "$1" in
        --date)
            DATE_MODE=1
            # Optional explicit YYMMDD as the next token, so `--date 260616 "title"` works.
            # A non-6-digit next token is the title, leaving DATE_VALUE empty (= today).
            if [ $# -ge 2 ] && printf '%s' "$2" | grep -qE '^[0-9]{6}$'; then
                DATE_VALUE="$2"
                shift
            fi
            ;;
        --date=*)
            DATE_MODE=1
            DATE_VALUE="${1#--date=}"
            ;;
        --)
            shift
            if [ $# -gt 0 ] && [ -z "$RAW" ]; then RAW="$1"; fi
            break
            ;;
        -*)
            echo "error: unknown option: $1 (supported: --date[=YYMMDD])" >&2
            exit 1
            ;;
        *)
            if [ -z "$RAW" ]; then RAW="$1"; fi
            ;;
    esac
    shift
done

if [ -z "$RAW" ] && [ "$DATE_MODE" -eq 0 ]; then
    echo "usage: leanplan-new <slug-or-title> | <PROJ-123> | --date[=YYMMDD] <slug-or-title>" >&2
    exit 1
fi

if [ "$DATE_MODE" -eq 1 ] && [ -n "$DATE_VALUE" ]; then
    case "$DATE_VALUE" in
        *[!0-9]*) echo "error: --date value must be YYMMDD (6 digits): $DATE_VALUE" >&2; exit 1 ;;
    esac
    if [ "${#DATE_VALUE}" -ne 6 ]; then
        echo "error: --date value must be YYMMDD (6 digits): $DATE_VALUE" >&2
        exit 1
    fi
fi

WIDTH="${LEANPLAN_ID_WIDTH:-4}"
case "$WIDTH" in
    ''|*[!0-9]*) echo "error: LEANPLAN_ID_WIDTH must be a positive integer" >&2; exit 1 ;;
esac

# --- resolve the feature id by form ---
if [ "$DATE_MODE" -eq 1 ]; then
    # Form 1: date id — <YYMMDD>-<slug>. The slug is kept (unlike the tracker-key form)
    # because a bare date collides whenever two features start the same day.
    if [ -z "$RAW" ]; then
        echo "error: --date needs a title for the slug (date ids are <YYMMDD>-<slug>)" >&2
        exit 1
    fi
    SLUG=$(slugify "$RAW")
    if [ -z "$SLUG" ]; then
        echo "error: '$RAW' has no slug-able characters — provide letters or digits" >&2
        exit 1
    fi
    if [ -n "$DATE_VALUE" ]; then
        DATE="$DATE_VALUE"
    else
        DATE=$(date +%y%m%d)
    fi
    FEATURE_ID="$DATE-$SLUG"
elif printf '%s' "$RAW" | grep -qE '^[A-Z][A-Z0-9]*-[0-9]+$'; then
    # Form 2: explicit tracker key (e.g. Jira NEWCS-3595) — used verbatim and BARE.
    # No slug: the key is globally unique and human-legible on its own. It already
    # matches [A-Z0-9-] so it is path-safe (no '/' or '..'); do NOT slugify (that would
    # lowercase it). The same key may also be noted under Requirements ## Upstream.
    FEATURE_ID="$RAW"
else
    # Form 3: repo-local sequence id — <NNNN>-<slug> (the default).
    SLUG=$(slugify "$RAW")
    if [ -z "$SLUG" ]; then
        echo "error: '$RAW' has no slug-able characters — provide letters or digits" >&2
        exit 1
    fi
    # If the arg already names an existing feature dir (e.g. someone passed an existing
    # "0007-foo" id), refuse rather than re-number it into docs/features/00NN-0007-foo.
    if [ -d "$FEATURES_ROOT/$SLUG" ]; then
        echo "error: $FEATURES_ROOT/$SLUG already exists — pass a new title, or edit that feature directly" >&2
        exit 2
    fi
    # Scan existing feature dirs for the highest leading number, counting ONLY ids whose
    # number is exactly WIDTH digits — the zero-padded shape this allocator produces.
    # That width gate is load-bearing: it excludes 6-digit YYMMDD date ids, which would
    # otherwise parse as gigantic sequence numbers (260616) and poison allocation.
    # Tracker-key dirs and other legacy dirs are likewise skipped and coexist. Numbers
    # are monotonic: gaps are never refilled (0001,0003 -> next 0004). (Limitation: ids
    # past 10^WIDTH-1, or a mid-project LEANPLAN_ID_WIDTH change, fall outside the gate —
    # both out of scope for one-deployment-sized feature work.)
    max=0
    if [ -d "$FEATURES_ROOT" ]; then
        for d in "$FEATURES_ROOT"/*/; do
            [ -d "$d" ] || continue                 # guards the no-match glob without `shopt -s nullglob`
            base=$(basename "$d")
            num=${base%%-*}
            case "$base" in "$num"-*) : ;; *) continue ;; esac   # require <num>-<rest> shape
            case "$num" in *[!0-9]*) continue ;; esac            # leading segment must be all digits
            [ "${#num}" -eq "$WIDTH" ] || continue               # ...and exactly WIDTH wide (excludes dates)
            val=$((10#$num))                         # 10# forces base-10 so 0008/0009 aren't parsed as octal
            [ "$val" -gt "$max" ] && max=$val
        done
    fi
    next=$((max + 1))
    NNNN=$(printf "%0${WIDTH}d" "$next")             # only ever feed the already-decimal $next to printf
    FEATURE_ID="$NNNN-$SLUG"
fi

DIR="$FEATURES_ROOT/$FEATURE_ID"

# Atomic allocation: `mkdir` on the leaf (no -p) IS the existence check, so two
# concurrent runs that computed the same id can't both succeed — the race loser's
# mkdir fails and we exit 2 rather than silently clobbering its stubs (the TOCTOU
# a separate `[ -e ]`-then-`mkdir -p` left open). The parent is created idempotently
# first so the leaf mkdir is the only racing operation.
mkdir -p "$FEATURES_ROOT"
if ! mkdir "$DIR" 2>/dev/null; then
    echo "error: $DIR already exists — refusing to overwrite" >&2
    exit 2
fi

cat > "$DIR/requirements.md" <<EOF
# $FEATURE_ID — <short biz-framed title>

## Problem

<!-- what biz pain or opportunity drives this? who feels it? what is currently broken, missing, or constrained? -->

## Outcome

<!-- biz future state + the signal that confirms it, folded into one paragraph. Don't split into a separate "Success metric" section. -->

<!-- Delete sections below if not applicable. -->

## Guarantee

<!-- Conditional — only when continuous domain properties (system-policy intent) exist:
why a cross-cutting property matters, stated as intent without an observable predicate
(the observable form is Spec ## Constraint). Delete if none. -->

## Non-goals

<!-- only when biz-scope edges are genuinely ambiguous -->

## Upstream

<!-- only when Jira / PRD / Slack refs exist. These are metadata, not identity — even
when the feature id itself is a tracker key (Jira-key form), note the URL / related refs here. -->
EOF

cat > "$DIR/spec.md" <<EOF
# $FEATURE_ID — Spec

## Behavior

<!-- Add episode-verifiable items below as:
###   B-<N>: <kebab-slug>
followed by "when X, Y happens" prose. One item per behavior. -->

## Constraint

<!-- Conditional — delete this section if no continuous constraints exist.
Add items as:
###   C-<N>: <kebab-slug>
for SLA, non-blocking, idempotency, integrity, environmental bindings. -->

<!-- Optional section below; delete if not applicable. -->

## Non-goals

<!-- only when tech-scope edges are ambiguous -->
EOF

cat > "$DIR/design.md" <<EOF
# $FEATURE_ID — Design

## Architecture

<!-- brief caption: what this diagram shows -->

\`\`\`mermaid
flowchart LR
    A[component-A] --> B[component-B]
\`\`\`

<!-- Add Decision blocks below, each as:
##   D-<N>: <kebab-slug>
with a one-line WHAT and a one-line WHY (trivial) or a rationale anchor (non-trivial):
See rationale at [design-rationale.md#D-<N>-<slug>]. -->
EOF

cat > "$DIR/design-rationale.md" <<EOF
# $FEATURE_ID — Design Rationale

<!-- One ## D-<N>: <slug> per non-trivial decision only. Free-form prose body;
typical content: forces at play, alternatives considered, chosen path, invalidation
hints. No prescribed schema — capture reasoning, don't fill a form. -->
EOF

cat > "$DIR/tasks.md" <<EOF
# $FEATURE_ID — Tasks

<!-- Doc-level Guidelines section is conditional — include only when feature-wide
work-stance rules genuinely apply (base branch, canary sequence, coordination). -->

## DAG

\`\`\`mermaid
flowchart LR
    placeholder[fill in tasks]
\`\`\`

<!-- caption: what the tracks represent; 1-2 sentences. -->

<!-- Add task cards below, each as:
##   T: <track-prefix><N>
- **Goal**: <WHAT + HOW; inline Spec#B-<N>-<slug> / Spec#C-<N>-<slug> / Design#D-<N>-<slug> anchors>
- **Repo**: <path or repo name>
- **Completion**: <observable verification, cites Spec anchors>
- **Dependencies**: <prior task IDs as enablers | none>
- **Guidelines** (conditional): <task-level work-stance rules>
-->
EOF

# H1 above is "$FEATURE_ID — Tasks" by design (the artifact node is "Tasks", not "Plan" —
# framework-design.md §8; the file is tasks.md); fixtures/valid and the validator/selftest depend on this.
echo "scaffolded $FEATURE_ID at $DIR (5 files)" >&2
echo "$DIR"
exit 0
